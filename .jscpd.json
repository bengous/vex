{
  "absolute": false,
  "gitignore": true,
  "ignore": [
    "**/*.test.ts",
    "**/*.e2e.test.ts",
    ".claude/**",
    "**/.claude/**",
    "AI.md",
    "**/AI.md",
    "GEMINI.md",
    "**/GEMINI.md",
    "**/AGENTS.md",
    "**/CLAUDE.md",
    "src/providers/codex-cli/shell_snapshots/**",
