{
  "name": "vex",
  "version": "0.1.0",
  "private": true,
  "description": "Visual Explorer - VLM-powered visual analysis tool for web layouts",
  "sideEffects": [
    "src/providers/init.ts"
  ],
  "bin": {
    "vex": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "bun test src/ --ignore '**/e2e/**'",
    "test:all": "bun test src/",
    "test:watch": "bun test --watch src/",
    "test:e2e": "bun test src/e2e/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/bun": "^1.3.8",
    "bun-types": "^1.3.8",
    "playwright": "^1.58.1"
  },
  "dependencies": {
    "@effect/cli": "^0.73.1",
    "@effect/platform-bun": "^0.87.1",
    "effect": "^3.19.15",
    "sharp": "^0.34.5"
  }
}
